    let responseText = data.content[0].text;
    responseText = responseText.replace(/```json
?/g, "").replace(/```
?/g, "").trim();
    const jsonResponse = JSON.parse(responseText);
    // 在 React 组件中使用这份结构化数据
  }
} catch (error) {
  console.error("Error in Claude completion:", error);
